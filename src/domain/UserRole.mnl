package domain

enum UserRole {
    ADMIN,      // 系统管理员
    MANAGER,    // 项目经理
    DEVELOPER,  // 开发者
    TESTER,     // 测试员
    VIEWER      // 只读用户
;
    
    fn canManageUsers() -> bool {
        return this == ADMIN
    }
    
    fn canCreateProjects() -> bool {
        return this == ADMIN || this == MANAGER
    }
    
    fn canManageAllProjects() -> bool {
        return this == ADMIN
    }
}