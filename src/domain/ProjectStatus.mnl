package domain

enum ProjectStatus {
    PLANNING,   // 规划中
    ACTIVE,     // 进行中
    ON_HOLD,    // 暂停
    COMPLETED,  // 已完成
    CANCELLED   // 已取消
;
    
    fn isActive() -> bool {
        return this == PLANNING || this == ACTIVE
    }
    
    fn isFinished() -> bool {
        return this == COMPLETED || this == CANCELLED
    }
}